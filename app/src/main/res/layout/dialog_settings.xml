<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secret Settings"
            android:textColor="#00D4AA"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- MQTT Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MQTT Broker"
            android:textColor="#8080A0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etBrokerIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.1.100"
            android:textColor="#FFFFFF"
            android:textColorHint="#404060"
            android:background="#252540"
            android:padding="12dp"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Port"
            android:textColor="#8080A0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etBrokerPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1883"
            android:text="1883"
            android:textColor="#FFFFFF"
            android:textColorHint="#404060"
            android:background="#252540"
            android:padding="12dp"
            android:inputType="number"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#303050"
            android:layout_marginBottom="16dp" />

        <!-- Patrol Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patrol Controls"
            android:textColor="#00D4AA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Patrol Route Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patrol Route"
            android:textColor="#8080A0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerPatrolRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252540"
            android:padding="12dp"
            android:spinnerMode="dropdown"
            android:layout_marginBottom="16dp" />

        <!-- Loitering Threshold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loitering Threshold (seconds)"
            android:textColor="#8080A0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etLoiteringThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="180"
            android:text="180"
            android:textColor="#FFFFFF"
            android:textColorHint="#404060"
            android:background="#252540"
            android:padding="12dp"
            android:inputType="number"
            android:layout_marginBottom="16dp" />

        <!-- Queue Max People -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Queue People"
            android:textColor="#8080A0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etQueueMaxPeople"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="5"
            android:text="5"
            android:textColor="#FFFFFF"
            android:textColorHint="#404060"
            android:background="#252540"
            android:padding="12dp"
            android:inputType="number"
            android:layout_marginBottom="16dp" />

        <!-- Detection Toggles Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detection Settings"
            android:textColor="#00D4AA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Loitering Detection Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Loitering Detection"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <Switch
                android:id="@+id/switchLoitering"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Smoking Detection Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Smoking Detection"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <Switch
                android:id="@+id/switchSmoking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Fallen Person Detection Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fallen Person Detection"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <Switch
                android:id="@+id/switchFallenPerson"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Unauthorized Access Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Unauthorized Access"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <Switch
                android:id="@+id/switchUnauthorizedAccess"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#303050"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Patrol Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnStartPatrol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Start Patrol"
                android:textColor="#00D4AA"
                android:background="#252540" />

            <Button
                android:id="@+id/btnStopPatrol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Stop Patrol"
                android:textColor="#FF6B6B"
                android:background="#252540" />
        </LinearLayout>

        <!-- Save/Cancel Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="#8080A0"
                android:background="@android:color/transparent"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                android:textColor="#00D4AA"
                android:background="@android:color/transparent" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
